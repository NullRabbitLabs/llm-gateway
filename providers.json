{
  "auto_priority": ["ollama", "deepseek", "zai", "moonshot", "gemini", "openai", "anthropic"],
  "providers": {
    "deepseek": {
      "kind": "openai_compatible",
      "base_url": "https://api.deepseek.com",
      "env_key": "DEEPSEEK_API_KEY",
      "env_model": "DEEPSEEK_MODEL",
      "default_model": "deepseek-v4-flash",
      "timeout": 300,
      "api_params": { "max_tokens": 8192 },
      "features": { "reasoning_content": true, "tool_calls": true, "json_mode": false },
      "pricing": { "input_per_1k_microcents": 0.12, "output_per_1k_microcents": 0.20 }
    },
    "zai": {
      "kind": "openai_compatible",
      "base_url": "https://api.z.ai/api/paas/v4",
      "env_key": "ZAI_API_KEY",
      "env_model": "ZAI_MODEL",
      "default_model": "glm-4.6",
      "timeout": 300,
      "api_params": { "max_tokens": 8192 },
      "model_params": {
        "glm-4.6": { "temperature": 1.0, "extra_body": { "thinking": { "type": "disabled" } } },
        "glm-4.5-air": { "temperature": 1.0 }
      },
      "features": { "tool_calls": true, "json_mode": false },
      "pricing": { "input_per_1k_microcents": 60.0, "output_per_1k_microcents": 220.0 }
    },
    "moonshot": {
      "kind": "openai_compatible",
      "base_url": "https://api.moonshot.ai/v1",
      "env_key": "MOONSHOT_API_KEY",
      "env_model": "MOONSHOT_MODEL",
      "default_model": "kimi-k2.6",
      "timeout": 300,
      "api_params": { "max_tokens": 8192 },
      "model_params": {
        "kimi-k3": { "temperature": 1.0 },
        "kimi-k2.6": { "temperature": 0.6, "extra_body": { "thinking": { "type": "disabled" } } }
      },
      "features": { "tool_calls": true, "json_mode": false },
      "pricing": { "input_per_1k_microcents": 95.0, "output_per_1k_microcents": 400.0 }
    },
    "openai": {
      "kind": "openai_compatible",
      "env_key": "OPENAI_API_KEY",
      "env_model": "OPENAI_MODEL",
      "default_model": "gpt-4o-mini",
      "timeout": 300,
      "features": { "tool_calls": true, "json_mode": true },
      "pricing": { "input_per_1k_microcents": 15.0, "output_per_1k_microcents": 60.0 }
    },
    "anthropic": {
      "kind": "anthropic",
      "env_key": "ANTHROPIC_API_KEY",
      "env_model": "ANTHROPIC_MODEL",
      "default_model": "claude-sonnet-5",
      "timeout": 300,
      "api_params": { "max_tokens": 16000 },
      "features": { "tool_calls": true },
      "pricing": { "input_per_1k_microcents": 300.0, "output_per_1k_microcents": 1500.0 }
    },
    "gemini": {
      "kind": "gemini",
      "env_key": "GEMINI_API_KEY",
      "env_model": "GEMINI_MODEL",
      "default_model": "gemini-2.0-flash",
      "api_params": { "temperature": 0.1 },
      "features": { "tool_calls": false, "json_mode": true },
      "pricing": { "input_per_1k_microcents": 0.10, "output_per_1k_microcents": 0.40 }
    },
    "ollama": {
      "kind": "ollama",
      "env_host": "OLLAMA_HOST",
      "env_model": "OLLAMA_MODEL",
      "default_model": "qwen2.5-coder:14b",
      "timeout": 120,
      "features": { "tool_calls": true },
      "pricing": { "input_per_1k_microcents": 0, "output_per_1k_microcents": 0 }
    }
  }
}
